# WordPress REST API
ADANABOSANMA_WP_BASE_URL=https://adanabosanmaavukati.org
ADANABOSANMA_WP_USERNAME=your-wordpress-username
ADANABOSANMA_WP_APP_PASSWORD=your-application-password

# Alternatif değişken adları (mevcut .env uyumu)
# ADANAAVUKAT_WP_USERNAME=
# ADANAAVUKAT_WP_APP_PASSWORD=

# Otomatik makale üretimi (scripts/generate-wp-article.mjs) için kullanılan adlar.
# GitHub Actions bu adlarla ortam değişkeni sağlar; yerelde de bunları kullanabilirsiniz.
WP_BASE_URL=https://adanabosanmaavukati.org
WP_USERNAME=your-wordpress-username
WP_APPLICATION_PASSWORD=your-application-password
# Yayın durumu: draft veya publish. Kod varsayılanı publish'tir; yerel testte draft önerilir.
WP_POST_STATUS=draft

# Gemini API
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_ENABLE_SEARCH_GROUNDING=true
