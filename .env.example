# WordPress REST API
ADANABOSANMA_WP_BASE_URL=https://adanabosanmaavukati.org
ADANABOSANMA_WP_USERNAME=your-wordpress-username
ADANABOSANMA_WP_APP_PASSWORD=your-application-password

# Alternatif değişken adları (mevcut .env uyumu)
# ADANAAVUKAT_WP_USERNAME=
# ADANAAVUKAT_WP_APP_PASSWORD=

# Gemini API
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_ENABLE_SEARCH_GROUNDING=true
